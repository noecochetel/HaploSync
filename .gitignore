# Ignore everything by default
*

# Allow directories to be explored
!*/

# Re-ignore private/unwanted directories
.obsidian/
private_dev/
.Rproj.user/
__pycache__/

# Root-level files
!/*.md
!/*.Rproj
!/.gitignore

# Tracked directories
!documents/
!documents/**
!media/
!media/**
!scripts/
!scripts/**
!support_scripts/
!support_scripts/**
!lib_files/
!lib_files/**

# Exclude generated/temporary files even inside tracked directories
# (these rules come last to override the directory includes above)
*.pyc
**/.DS_Store
.DS_Store
