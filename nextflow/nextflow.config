/*
 * HaploSync Nextflow Configuration
 */

manifest {
    name            = 'HaploSync'
    author          = 'noecochetel'
    description     = 'Haplotype-resolved pseudomolecule assembly pipeline'
    version         = '2.0'
    nextflowVersion = '>=23.04'
}

// --------------------------------------------------------------------------
// Default parameters
// --------------------------------------------------------------------------
params {
    help            = false  // Print help message and exit

    // --- HaploSync installation directory ---
    haplosync_dir   = null   // Absolute path to HaploSync root (e.g. /path/to/HaploSync)

    // --- Required inputs ---
    // Provide (markers AND markers_map) and/or guide_genome
    input_fasta     = null   // Draft assembly FASTA (-i)

    // --- Genetic map ---
    markers         = null   // Marker hits BED file (-n)
    markers_map     = null   // Markers genetic map (-m)

    // --- Reference genome ---
    guide_genome    = null   // Guide/reference genome FASTA (-g/--guide)
    local_alignment = null   // Existing PAF file, skips minimap2 (-l)
    run_alignment   = false  // Run minimap2 alignment (--align)
    mapping_tool    = null   // Minimap2 options string (-t, default: '--cs -x asm20 -r 1000')
    hitgap          = null   // Max gap between alignment hits in bp (--hitgap, default: 100000)
    distance1       = null   // Max Hap1 adjacency distance in bp (--distance1, default: 2000000)
    distance2       = null   // Max Hap2 adjacency distance in bp (--distance2, default: 4000000)
    reuse_intermediate = false // Reuse nucmer intermediate files (--reuse_intermediate)

    // --- Optional inputs ---
    input_agp       = null   // Input AGP structure (-a)
    gff3            = null   // Gene annotation GFF3 (--GFF3)
    exclusion       = null   // Mutually exclusive sequence pairs (-e)
    known           = null   // Known same-haplotype sequences (-k)
    alternative_groups = null // Alternative haplotype sequence pairs
    Require1        = null   // Sequences required in Hap1 (--R1)
    Require2        = null   // Sequences required in Hap2 (--R2)
    force_direction1 = false // Force marker direction for --R1 (--F1)
    force_direction2 = false // Force marker direction for --R2 (--F2)
    minR1           = null   // Minimum length for --R1 sequences
    minR2           = null   // Minimum length for --R2 sequences
    Blacklist1      = null   // Blacklisted sequences for Hap1 (--B1)
    Blacklist2      = null   // Blacklisted sequences for Hap2 (--B2)
    input_groups    = null   // Sequence grouping file (--input_groups)
    path1           = null   // Pre-defined Hap1 tiling path file (-1/--path1)
    path2           = null   // Pre-defined Hap2 tiling path file (-2/--path2)

    // --- Assembly behaviour ---
    No2             = false  // Skip Hap2 reconstruction (--N2)
    gap             = null   // Gap size in bp (--gapsize, default: 1000)
    conc            = null   // Concatenate unplaced sequences with this gap size (--concatenate)
    filter_hits     = false  // Remove sequences with intra-sequence marker duplication (-f)
    extended_region = false  // Extend sequence association to all chromosome markers (--extended)
    conflict_resolution = null // Conflict resolution policy: exit | ignore | release (--conflict)
    allow_rearrangements = false // Allow rearrangements between haplotypes (--allow_rearrangements)
    required_as_path    = false  // Treat --R1/--R2 as full tiling paths (--required_as_path)

    // --- QC ---
    skip_chimeric_qc = false            // Skip chimeric sequence QC (--skip_chimeric_qc)
    disable_marker_ploidy_check = false // Disable marker ploidy check (--disable_marker_ploidy_check)
    only_markers        = false         // Limit rejected-seq QC to marker-bearing seqs (--only_markers)
    avoid_rejected_qc   = false         // Skip QC of chr-assigned but unplaced seqs (--avoid_rejected_qc)

    // --- Output ---
    out             = 'out'
    prefix          = 'NEW'
    outdir          = 'results'

    // --- Resources ---
    cores           = 4

    // --- Extra flags ---
    haplodup_opts     = ''   // Extra HaploDup flags as a quoted string

    // --- HaploDup ---
    run_haplodup    = false  // Run HaploDup after reconstruction

    // Optional inputs
    reference                = null   // Reference genome for dotplots (-r)
    functional_annotation    = null   // Functional annotation per transcript (-a)
    rejected_list            = null   // Rejected sequences list for QC (--rejected_list)

    // Grouping
    legacy_groups            = null   // Legacy grouping file (--legacy_groups)

    // Alignment thresholds
    hit_identity             = null   // Min genome mapping identity     (--hit_identity,    default: 90)
    hit_coverage             = null   // Min genome mapping hit length   (--hit_coverage,    default: 3000)
    gene_identity            = null   // Min gene mapping identity       (--gene_identity,   default: 95)
    gene_coverage            = null   // Min gene mapping coverage       (--gene_coverage,   default: 95)
    unbalanced_ratio         = null   // Gene count ratio threshold      (--unbalanced_ratio, default: 0.33)

    // Gene mapping
    haplodup_feature         = null   // GFF feature type [CDS|mRNA]     (--feature,         default: CDS)
    haplodup_window          = null   // Window size for unbalanced gene search (--window,   default: 10)
    haplodup_allowed         = null   // Allowed unbalanced genes/window  (--allowed,         default: 5)

    // Reuse / skip
    reuse_mappings           = false  // Reuse existing genome alignments (--reuse_mappings)
    reuse_dotplots           = false  // Reuse existing dotplots          (--reuse_dotplots)
    reuse_gmap               = false  // Reuse existing GMAP mappings     (--reuse_gmap)
    skip_chr_pair_reports    = false  // Skip per-chr-pair overview reports (--skip_chr_pair_reports)
    skip_dotplots_by_chr     = false  // Skip individual chr-vs-chr dotplots (--skip_dotplots_by_chr)
    only_paired_dotplots     = false  // Only generate matched-pair dotplots (--only_paired_dotplots)
}

// --------------------------------------------------------------------------
// Resource labels
// --------------------------------------------------------------------------
process {
    errorStrategy = 'terminate'

    withLabel: 'process_low' {
        cpus   = 4
        memory = '8.GB'
        time   = '2.h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '12.h'
    }
    withLabel: 'process_high' {
        cpus   = 24
        memory = '64.GB'
        time   = '48.h'
    }
}

// --------------------------------------------------------------------------
// Execution profiles
// --------------------------------------------------------------------------
profiles {

    standard {
        process.executor = 'local'
    }

    conda {
        conda.enabled  = true
        conda.useMamba = false
    }

    mamba {
        conda.enabled  = true
        conda.useMamba = true
    }

    hpc {
        process.executor = 'slurm'
        conda.enabled    = true
        conda.useMamba   = true
    }

    test {
        params.input_fasta  = 'test/input.fasta'
        params.guide_genome = 'test/guide.fasta'
        params.out          = 'test_out'
        params.cores        = 4
    }
}
