/*
 * HaploSync Nextflow Configuration
 */

manifest {
    name            = 'HaploSync'
    author          = 'noecochetel'
    description     = 'Haplotype-resolved pseudomolecule assembly pipeline'
    version         = '2.0'
    nextflowVersion = '>=23.04'
}

// --------------------------------------------------------------------------
// Default parameters
// --------------------------------------------------------------------------
params {
    // --- Required inputs ---
    input_fasta     = null   // Draft assembly FASTA (-i)
    guide_genome    = null   // Guide/reference genome FASTA (-g)
    markers         = null   // Markers FASTA (-n)
    markers_map     = null   // Markers genetic map (-m)

    // --- Optional inputs ---
    input_agp       = null   // Input AGP structure (-a)
    input_groups    = null   // Sequence grouping file (--input_groups)
    legacy_groups   = null   // Legacy grouping file (--legacy_groups)
    gff3            = null   // Gene annotation GFF3 (--GFF3)
    reference       = null   // Reference genome for HaploDup (-r)

    // --- Output ---
    out             = 'out'
    prefix          = 'NEW'
    outdir          = 'results'

    // --- Resources ---
    cores           = 4

    // --- HaploSplit options ---
    haplosplit_opts = ''     // Extra HaploSplit flags as a quoted string

    // --- HaploDup ---
    run_haplodup    = false  // Run HaploDup after HaploSplit
    haplodup_opts   = ''     // Extra HaploDup flags as a quoted string
}

// --------------------------------------------------------------------------
// Resource labels
// --------------------------------------------------------------------------
process {
    errorStrategy = 'terminate'

    withLabel: 'process_low' {
        cpus   = 4
        memory = '8.GB'
        time   = '2.h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '12.h'
    }
    withLabel: 'process_high' {
        cpus   = 24
        memory = '64.GB'
        time   = '48.h'
    }
}

// --------------------------------------------------------------------------
// Execution profiles
// --------------------------------------------------------------------------
profiles {

    standard {
        process.executor = 'local'
    }

    conda {
        conda.enabled  = true
        conda.useMamba = false
    }

    mamba {
        conda.enabled  = true
        conda.useMamba = true
    }

    hpc {
        process.executor = 'slurm'
        conda.enabled    = true
        conda.useMamba   = true
    }

    test {
        params.input_fasta  = 'test/input.fasta'
        params.guide_genome = 'test/guide.fasta'
        params.out          = 'test_out'
        params.cores        = 4
    }
}
